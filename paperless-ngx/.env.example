# Copy this file to .env and replace every CHANGE_ME value.

# Required database settings
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

# Local service paths
PAPERLESS_CONSUME_DIR=./originals
PAPERLESS_DATA_DIR=./data
PAPERLESS_MEDIA_DIR=./media
PAPERLESS_DB_DIR=./db

# Local service port
PAPERLESS_PORT=8081

# Regional settings
TZ=Europe/Madrid
OCR_LANGUAGES=spa+eng
