# Copy this file to .env and replace every CHANGE_ME value.

# Database settings
MYSQLROOTPWD=CHANGE_ME_MYSQL_ROOT_PASSWORD
VIKDBUSR=vikunja
VIKDBPWD=CHANGE_ME_DATABASE_PASSWORD
VIKDBNAME=vikunjadb

# Public URL
VIKDOMAIN=https://vikunja.example.com

# Local service data
DATA_DIR=./files

# Mail settings
MAILHOST=smtp.example.com
MAILPORT=587
MAILUSER=CHANGE_ME_SMTP_USER
MAILPASS=CHANGE_ME_SMTP_PASSWORD
MAILFROM=no-reply@example.com
